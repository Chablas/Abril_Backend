# Copia este archivo a ".env" EN LA VPS (no lo subas a git) y rellena los valores.
#
#   cp .env.example .env && nano .env

# Usuario y contraseña del admin de Grafana (primer login).
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# URL pública con la que se sirve Grafana detrás de Nginx (para que los enlaces
# y el login funcionen). Se sirve como subpath del dominio existente, NO un
# subdominio nuevo. Debe terminar en /logs/ (con la barra final).
GF_ROOT_URL=https://intranet.abril.pe/logs/
